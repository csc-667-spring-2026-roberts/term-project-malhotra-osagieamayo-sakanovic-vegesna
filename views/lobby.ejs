<%- include('partials/head', { title: 'Lobby — Skip-Bo Project' }) %>
  <h1>Lobby</h1>
  <p class="subtitle">You are signed in.</p>

  <div class="panel">
    <div class="lobby-user">
      <img src="<%= gravatarUrl %>" width="120" height="120" alt="">
      <div>
        <p><strong>Email</strong><br><%= user.email %></p>
        <p style="margin: 0.75rem 0 0 0; font-size: 0.85rem; color: #666;">User ID: <%= user.id %></p>
      </div>
    </div>
    <form action="/auth/logout" method="POST">
      <button type="submit">Log Out</button>
    </form>

    <hr style="margin: 1.25rem 0; border: none; border-top: 1px solid #ddd;">
    <p class="subtitle" style="margin-bottom: 0.5rem;">M8: client-side fetch</p>
    <button type="button" id="load-session-btn">Load session from server</button>
    <div id="activity-output" style="margin-top: 0.75rem;"></div>
    <template id="activity-row-template">
      <div class="panel" style="margin-top: 0.5rem;">
        <p data-field="message"></p>
        <p data-field="time" style="font-size: 0.85rem; color: #666; margin: 0;"></p>
      </div>
    </template>
  </div>
  <script defer src="/js/lobby.js"></script>
<%- include('partials/footer') %>
